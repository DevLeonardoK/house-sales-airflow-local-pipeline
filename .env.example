# ==========================================================
# Template de variáveis de ambiente.
# Copie para .env e preencha com seus valores:
#   cp .env.example .env
# ==========================================================

# UID do host para os arquivos criados pelo Airflow (Linux: use `id -u`)
AIRFLOW_UID=1000

# --- Credenciais do Kaggle (https://www.kaggle.com/settings -> Create New Token) ---
KAGGLE_USERNAME=seu_usuario_kaggle
KAGGLE_KEY=sua_api_key_kaggle

# --- Postgres de STORAGE (camada gold / serving) ---
PG_USER=dag_house_sales
PG_PASS=troque_esta_senha
PG_DB=dag_house_sales
# URL JDBC usada pelo job gold (Spark -> Postgres). Mesma host/porta/db acima.
PG_URL=jdbc:postgresql://postgres_storage:5432/dag_house_sales

# --- Postgres de METADADOS do Airflow ---
PG_AIRFLOW_USER=airflow
PG_AIRFLOW_PASS=troque_esta_senha
PG_AIRFLOW_DB=airflow

# --- MinIO (object storage S3-compatible) ---
MINIO_USER=minio
MINIO_PASS=troque_esta_senha

# --- Fernet key do Airflow (gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" ) ---
FERNET_KEY=gere_sua_fernet_key

# --- Conexão do Spark master (Airflow Connection id) ---
SPARK_MASTER_CONN_ID=spark_master

# --- Caminhos das camadas no MinIO (s3a) ---
BRONZE_MINIO_PATH=s3a://bronze/kc_house_data.csv
SILVER_ORIGINAL_MINIO_PATH=s3a://silver/silver_original
GOLD_MINIO_PATH=s3a://gold/
